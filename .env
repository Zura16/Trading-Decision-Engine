# Real-Time Trading Decision Engine Configurations

# Database: Default to SQLite for zero-setup. Swap to PostgreSQL if needed.
DATABASE_URL=sqlite:///trading_engine.db
# DATABASE_URL=postgresql://username:password@localhost:5432/trading_engine

# Active symbols for the engine (comma-separated)
# We support stock tickers and crypto pairs (via yfinance format)
SYMBOLS=AAPL,MSFT,BTC-USD

# Engine parameters
MODEL_PATH=xgboost_model.json
LOG_LEVEL=INFO
DASH_PORT=8050
DASH_HOST=127.0.0.1
